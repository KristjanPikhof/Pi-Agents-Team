  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.67.68",
    "@sinclair/typebox": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  }
