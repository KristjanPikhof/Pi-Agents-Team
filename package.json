{
  "name": "pi-agents-team",
  "version": "2026.4.23",
  "private": true,
  "description": "Pi package that turns the main session into an orchestrator for RPC-backed worker agents.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi",
    "extension",
    "orchestrator",
    "rpc"
  ],
  "homepage": "https://github.com/KristjanPikhof/pi-agents-team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KristjanPikhof/pi-agents-team.git"
  },
  "bugs": {
    "url": "https://github.com/KristjanPikhof/pi-agents-team/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "check": "npm run typecheck && npm test",
    "smoke:runtime": "tsx scripts/smoke/runtime-worker.ts",
    "smoke:team": "tsx scripts/smoke/team-flow.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "@mariozechner/pi-tui": "^0.69.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typebox": "^1.0.56",
    "typescript": "^6.0.3"
  }
}
