{
  "name": "pi-agents-team",
  "version": "2026.4.23",
  "description": "Pi extension that turns one coding session into a multi-agent team with background RPC worker agents.",
  "license": "MIT",
  "type": "module",
  "author": {
    "name": "Kristjan Pikhof",
    "url": "https://github.com/KristjanPikhof"
  },
  "keywords": [
    "pi",
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "extension",
    "ai-agents",
    "multi-agent",
    "agent-team",
    "coding-agent",
    "orchestrator",
    "background-agents",
    "rpc",
    "developer-tools"
  ],
  "homepage": "https://github.com/KristjanPikhof/pi-agents-team",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KristjanPikhof/pi-agents-team.git"
  },
  "bugs": {
    "url": "https://github.com/KristjanPikhof/pi-agents-team/issues"
  },
  "main": "./extensions/index.ts",
  "exports": {
    ".": "./extensions/index.ts"
  },
  "files": [
    "extensions/",
    "src/",
    "prompts/",
    "profiles/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "check": "npm run typecheck && npm test",
    "smoke:runtime": "tsx scripts/smoke/runtime-worker.ts",
    "smoke:team": "tsx scripts/smoke/team-flow.ts"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "dependencies": {
    "typebox": "^1.0.56"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.69.0",
    "@mariozechner/pi-tui": ">=0.69.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.69.0",
    "@mariozechner/pi-tui": "^0.69.0",
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
